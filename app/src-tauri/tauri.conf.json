{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gmux",
  "version": "0.1.0",
  "identifier": "dev.gmux.test",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1421",
    "frontendDist":       "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label":       "main",
        "title":       "gmux",
        "url":         "index.html",
        "width":       1400,
        "height":      900,
        "minWidth":    800,
        "minHeight":   500,
        "resizable":   true,
        "decorations": true,
        "transparent": false,
        "fullscreen":  false,
        "center":      true
      },
      {
        "label":       "aquarium",
        "title":       "gmux — aquarium",
        "url":         "aquarium.html",
        "width":       900,
        "height":      600,
        "minWidth":    400,
        "minHeight":   300,
        "resizable":   true,
        "decorations": true,
        "transparent": false,
        "fullscreen":  false,
        "visible":     false,
        "center":      false,
        "x":           80,
        "y":           80
      },
      {
        "label":       "dashboard",
        "title":       "gmux — agent display",
        "url":         "dashboard/index.html",
        "width":       1800,
        "height":      1100,
        "minWidth":    900,
        "minHeight":   600,
        "resizable":   true,
        "decorations": true,
        "transparent": false,
        "fullscreen":  false,
        "visible":     false,
        "center":      false,
        "x":           120,
        "y":           120
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
